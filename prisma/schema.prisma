generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MoodEntry {
  id        Int      @id @default(autoincrement())
  mood      Int
  createdAt DateTime @default(now())
}

// Key-value settings (legacy / misc)
model Setting {
  key   String @id
  value String
}

// Multiple mood characters, each with its own URL slug and mood
model Character {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String?
  mood      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
