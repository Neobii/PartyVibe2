generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MoodEntry {
  id        Int      @id @default(autoincrement())
  mood      Int
  createdAt DateTime @default(now())
}

// Key-value settings (e.g. character_slug → URL segment for mood character page)
model Setting {
  key   String @id
  value String
}
